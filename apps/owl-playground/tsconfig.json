{
  "extends": "@cyberowl-town/tsconfig/react.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx", "./__tests__/**/*.spec.ts"],
  "exclude": ["node_modules"]
}
