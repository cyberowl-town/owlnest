{
  "name": "owl-template",
  "version": "1.0.0",
  "private": true,
  "description": "Something InterNest template something.",
  "license": "AGPL-3.0-or-later",
  "author": "CyberOwl Town <cyberowltownmaster@gmail.com>",
  "scripts": {
    "prepare": "lefthook install --reset-hooks-path",
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --fix . --no-error-on-unmatched-pattern",
    "format": "oxfmt --check --no-error-on-unmatched-pattern",
    "format:fix": "oxfmt . --no-error-on-unmatched-pattern"
  },
  "devDependencies": {
    "lefthook": "2.1.6",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "turbo": "2.9.9"
  },
  "packageManager": "pnpm@11.0.8",
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux"
      ],
      "cpu": [
        "current",
        "x64"
      ]
    }
  }
}
