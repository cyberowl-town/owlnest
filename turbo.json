{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".nuxt/**", ".output/**", "dist/**"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "__tests__/**/*.test.ts"],
      "dependsOn": ["^test"]
    },
    "deploy": {
      "inputs": ["$TURBO_DEFAULT$", "dist/**"],
      "dependsOn": ["build", "test"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "//#quality": {
      "dependsOn": ["//#lint", "//#format"]
    },
    "//#quality:fix": {
      "dependsOn": ["//#lint:fix", "//#format:fix"]
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#format": {},
    "//#format:fix": {
      "dependsOn": ["//#lint:fix"],
      "cache": false
    }
  }
}
