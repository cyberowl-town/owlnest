{
  "$schema": "https://turborepo.dev/schema.json",
  "globalPassThroughEnv": ["PLAYWRIGHT_*"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "dependsOn": ["^build"]
    },
    "test": {
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "deploy": {
      "dependsOn": ["build", "test"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "//#quality": {
      "dependsOn": ["//#lint", "//#format"]
    },
    "//#quality:fix": {
      "dependsOn": ["//#lint:fix", "//#format:fix"]
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#format": {},
    "//#format:fix": {
      "dependsOn": ["//#lint:fix"],
      "cache": false
    }
  }
}
